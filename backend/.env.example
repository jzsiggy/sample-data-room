# Backend configuration. Copy to .env for local development.
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Postgres (matches docker-compose). The test harness uses the dataroom_test DB.
DATABASE_URL=postgresql://dataroom:dataroom@localhost:5432/dataroom?schema=public
TEST_DATABASE_URL=postgresql://dataroom:dataroom@localhost:5432/dataroom_test?schema=public

# Object storage (MinIO locally; swap these for S3/R2 in production).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dataroom
