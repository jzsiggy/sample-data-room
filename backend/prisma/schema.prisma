// Domain models are added per feature slice.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The authenticated person who signs in, creates rooms, and shares files.
model Owner {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
  rooms        Room[]
}

// A named container that holds files and is shared as a single unit.
model Room {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  files     File[]

  @@index([ownerId])
}

// An uploaded artifact inside a room — its bytes (in object storage, keyed by
// `storageKey`) plus a name, MIME type, and size. Deleting the room cascades
// these rows away; the storage objects are removed by the route handler.
model File {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String
  contentType String
  size        Int
  storageKey  String
  createdAt   DateTime @default(now())

  @@index([roomId])
}

// A server-side login session. Its id is a cryptographically random token that
// is carried (signed) in the httpOnly `sid` cookie — see ADR-0001.
model Session {
  id        String   @id
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ownerId])
}
